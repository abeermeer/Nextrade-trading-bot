# Admin (required — used by seed_admin.py on startup)
ADMIN_PASSWORD=your_admin_password

# JWT Secret (required for auth)
JWT_SECRET=your-256-bit-jwt-secret

# Encryption Key (required for exchange key storage)
ENCRYPTION_KEY=your-fernet-encryption-key

# Database (default: SQLite, override for PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./trading.db

# Redis (required for bot operation)
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://dist-rho-sandy-41.vercel.app

# Stripe (required for subscriptions)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_basic_xxx
STRIPE_PRICE_PRO=price_pro_xxx
STRIPE_PRICE_ENTERPRISE=price_enterprise_xxx

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
